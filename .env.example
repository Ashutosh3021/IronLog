# Supabase (https://supabase.com) — create a project, enable Anonymous sign-ins, run data/schema.sql
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# GitHub Pages: add the same two keys as repository secrets (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY) so CI embeds them in the build.

# If anonymous signup returns 500: easiest fix is Supabase Dashboard → Authentication → Attack Protection
# (or Bot Protection) → turn OFF “Enable CAPTCHA protection”.
# To keep CAPTCHA on: choose Cloudflare Turnstile there, add the Turnstile *secret*, and set the site key here:
# VITE_TURNSTILE_SITE_KEY=0x4AAAA...
